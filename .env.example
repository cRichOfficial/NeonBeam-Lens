# NeonBeam Lens — Environment Configuration
# ──────────────────────────────────────────
# Copy this file to .env before starting the service:
#   cp .env.example .env


# ── Camera ───────────────────────────────────────────────────────────────────
#
# OpenCV camera index (integer).
# List available cameras on the host:
#   ls /dev/video*                  (Linux)
#   v4l2-ctl --list-devices         (Linux, requires v4l-utils)
#
#   0  → First camera  (USB webcam or Pi Camera)
#   1  → Second camera (if multiple are attached)
VISION_CAMERA_ID=0

# ── NPU / Hailo ──────────────────────────────────────────────────────────────
#
# For production on Raspberry Pi 5 + Hailo-8L:
#   Ensure /dev/hailo0 is passed through via the 'devices' block in
#   docker-compose.yml (see commented section) and that HailoRT runtime
#   libraries are installed on the Pi.
#
# In development (no Hailo hardware), the service starts without NPU inference.
# CPU-based OpenCV fallbacks are used for frame processing.


# ── Logging ──────────────────────────────────────────────────────────────────
#
# True   → DEBUG: frame timings, inference scores, calibration matrices
# False  → INFO: normal operation only
VISION_DEBUG_LOGGING=True
