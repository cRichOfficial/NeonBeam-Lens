# NeonBeam Lens — Environment Configuration
# ──────────────────────────────────────────
# Copy this file to .env before starting the service:
#   cp .env.example .env


# ── Camera ───────────────────────────────────────────────────────────────────
#
# OpenCV camera index (integer).
# List available cameras on the host:
#   ls /dev/video*                  (Linux)
#   v4l2-ctl --list-devices         (Linux, requires v4l-utils)
#
#   0  → First camera  (USB webcam or Pi Camera)
#   1  → Second camera (if multiple are attached)
VISION_CAMERA_ID=0

# Capture resolution. Set to "max" to use the sensor's full native resolution
# (recommended for best detection accuracy), or a specific "WIDTHxHEIGHT"
# value to cap it (e.g. "1920x1080" if full resolution is too slow).
CAMERA_RESOLUTION=max

# Set to True if using a wide-angle / fisheye lens (e.g. 175 FOV).
# Currently disabled by default as it requires manual tuning of K/D coefficients.
FISHEYE_LENS=False

# Physical height of your laser bed workspace in mm.
# This is used to flip the Y axis so that (0,0) is at the BOTTOM-LEFT corner
# of the bed (standard Cartesian convention), rather than the top-left.
# Measure the height of the area between your outermost AprilTags.
# If set to 0, no Y-flip is applied.
WORKSPACE_HEIGHT_MM=500


# ── NPU / Hailo ──────────────────────────────────────────────────────────────
#
# For production on Raspberry Pi 5 + Hailo-8L:
#   Ensure /dev/hailo0 is passed through via the 'devices' block in
#   docker-compose.yml (see commented section) and that HailoRT runtime
#   libraries are installed on the Pi.
#
# In development (no Hailo hardware), the service starts without NPU inference.
# CPU-based OpenCV fallbacks are used for frame processing.
USE_HAILO=False

# Path to the Hailo Executable Format (HEF) file
MODEL_PATH=app/models/yolov8s_seg.hef

# Detection confidence threshold (0.0 to 1.0)
DETECT_CONF_THRESHOLD=0.4


# ── Post-Processing ─────────────────────────────────────────────────────────
#
# Min/Max area filter (in physical mm^2)
# A 100x100mm coaster is 10000 mm^2.
MIN_WORKPIECE_AREA_MM2=500
MAX_WORKPIECE_AREA_MM2=160000

# Kernel size for morphological operations to bridge honeycomb gaps (px).
# Smaller values = tighter bounding boxes around workpieces.
# Larger values = better at merging fragmented dark objects into one blob.
HONEYCOMB_KERNEL_SIZE=25

# Extra pixels to expand the AprilTag exclusion mask beyond the detected tag border.
# Increase this if the white paper backing the AprilTags is being detected as a workpiece.
APRILTAG_MASK_PADDING=30


# ── Logging ──────────────────────────────────────────────────────────────────
#
# True   → DEBUG: frame timings, inference scores, calibration matrices
# False  → INFO: normal operation only
VISION_DEBUG_LOGGING=True
