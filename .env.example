# NeonBeam Lens — Environment Configuration
# ──────────────────────────────────────────
# Copy this file to .env before starting the service:
#   cp .env.example .env


# ── Camera ───────────────────────────────────────────────────────────────────
#
# OpenCV camera index (integer).
# List available cameras on the host:
#   ls /dev/video*                  (Linux)
#   v4l2-ctl --list-devices         (Linux, requires v4l-utils)
#
#   0  → First camera  (USB webcam or Pi Camera)
#   1  → Second camera (if multiple are attached)
VISION_CAMERA_ID=0

# Capture resolution. Set to "max" to use the sensor's full native resolution
# (recommended for best detection accuracy), or a specific "WIDTHxHEIGHT"
# value to cap it (e.g. "1920x1080" if full resolution is too slow).
CAMERA_RESOLUTION=max

# Enable Hardware HDR on supported sensors (e.g., IMX708 / Pi Camera v3).
# When set to True, libcamera will use Sensor-level HDR, which limits the
# maximum capture resolution to ~3MP (2304x1296) to improve dynamic range.
CAMERA_HDR=False

# Lens distortion model. Controls which OpenCV calibration model is used
# during the guided lens calibration workflow (POST /api/lens/calibrate-lens/*).
#   False (default) = standard pinhole + radial/tangential (5 coefficients).
#                     Suitable for lenses up to ~120° HFOV (e.g. IMX708 102°).
#   True            = Kannala-Brandt fisheye model (4 coefficients).
#                     Required for ultra-wide / fisheye lenses (>140° HFOV).
# Lens calibration is performed via the guided checkerboard workflow and saved
# to calibration_data/lens_calibration.json. Once saved, undistortion is applied
# automatically on every frame.
FISHEYE_LENS=False

# Physical height of your laser bed workspace in mm.
# This is used to flip the Y axis so that (0,0) is at the BOTTOM-LEFT corner
# of the bed (standard Cartesian convention), rather than the top-left.
# Measure the height of the area between your outermost AprilTags.
# If set to 0, no Y-flip is applied.
WORKSPACE_HEIGHT_MM=500

# ── Auto-Exposure Settling ────────────────────────────────────────────────────
#
# The IMX708 (and most Pi cameras) need several frames for the ISP auto-exposure
# algorithm to stabilize after startup or after a sensor-mode change. If a frame
# is returned with a mean brightness below MIN_FRAME_BRIGHTNESS, the service will
# retry up to AE_SETTLE_RETRIES times with AE_SETTLE_DELAY seconds between each
# attempt before giving up and returning the dark frame anyway.
#
# Symptoms of AE not settling: detect debug image appears completely black.
# Fix: increase AE_SETTLE_RETRIES or AE_SETTLE_DELAY, or lower MIN_FRAME_BRIGHTNESS.
MIN_FRAME_BRIGHTNESS=20
AE_SETTLE_RETRIES=10
AE_SETTLE_DELAY=0.1


# ── Detection ────────────────────────────────────────────────────────────────
#
# Maximum long-side resolution (px) for the detection pipeline.
# All expensive operations run on a downsampled working image and results are
# scaled back to full resolution for mm mapping. Default 1280 gives sub-second
# detection even at 12MP.
DETECT_MAX_DIM=1280

# Local-variance window size (px at 720p reference resolution).
# The detector computes per-pixel variance in a sliding window of this size.
# The window must span several honeycomb holes to capture the repeating texture.
# Increase if the honeycomb pattern is very coarse; decrease if workpieces
# have visible texture that's being mistaken for the bed.
DETECT_VARIANCE_WINDOW=25

# Min/Max area filter (in physical mm²).
# A 100×100mm coaster is 10,000 mm².
MIN_WORKPIECE_AREA_MM2=500
MAX_WORKPIECE_AREA_MM2=160000

# Kernel size for morphological close/dilate that bridges gaps within a
# workpiece blob (px at 720p reference).
HONEYCOMB_KERNEL_SIZE=25

# Extra pixels to expand the AprilTag exclusion mask beyond the detected tag
# border (px at 720p reference). Increase if the white paper backing the tags
# is being detected as a workpiece.
APRILTAG_MASK_PADDING=30


# ── Logging ──────────────────────────────────────────────────────────────────
#
# True   → DEBUG: frame timings, inference scores, calibration matrices
# False  → INFO: normal operation only
VISION_DEBUG_LOGGING=True
