# NeonBeam Lens — Environment Configuration
# ──────────────────────────────────────────
# Copy this file to .env before starting the service:
#   cp .env.example .env


# ── Camera ───────────────────────────────────────────────────────────────────
#
# OpenCV camera index (integer).
# List available cameras on the host:
#   ls /dev/video*                  (Linux)
#   v4l2-ctl --list-devices         (Linux, requires v4l-utils)
#
#   0  → First camera  (USB webcam or Pi Camera)
#   1  → Second camera (if multiple are attached)
VISION_CAMERA_ID=0

# Capture resolution. Set to "max" to use the sensor's full native resolution
# (recommended for best detection accuracy), or a specific "WIDTHxHEIGHT"
# value to cap it (e.g. "1920x1080" if full resolution is too slow).
CAMERA_RESOLUTION=max

# Enable Hardware HDR on supported sensors (e.g., IMX708 / Pi Camera v3).
# When set to True, libcamera will use Sensor-level HDR, which limits the
# maximum capture resolution to ~3MP (2304x1296) to improve dynamic range.
CAMERA_HDR=False

# Lens distortion model. Controls which OpenCV calibration model is used
# during the guided lens calibration workflow (POST /api/lens/calibrate-lens/*).
#   False (default) = standard pinhole + radial/tangential (5 coefficients).
#                     Suitable for lenses up to ~120° HFOV (e.g. IMX708 102°).
#   True            = Kannala-Brandt fisheye model (4 coefficients).
#                     Required for ultra-wide / fisheye lenses (>140° HFOV).
# Lens calibration is performed via the guided checkerboard workflow and saved
# to calibration_data/lens_calibration.json. Once saved, undistortion is applied
# automatically on every frame.
FISHEYE_LENS=False

# Physical height of your laser bed workspace in mm.
# This is used to flip the Y axis so that (0,0) is at the BOTTOM-LEFT corner
# of the bed (standard Cartesian convention), rather than the top-left.
# Measure the height of the area between your outermost AprilTags.
# If set to 0, no Y-flip is applied.
WORKSPACE_HEIGHT_MM=500

# ── Auto-Exposure Settling ────────────────────────────────────────────────────
#
# The IMX708 (and most Pi cameras) need several frames for the ISP auto-exposure
# algorithm to stabilize after startup or after a sensor-mode change. If a frame
# is returned with a mean brightness below MIN_FRAME_BRIGHTNESS, the service will
# retry up to AE_SETTLE_RETRIES times with AE_SETTLE_DELAY seconds between each
# attempt before giving up and returning the dark frame anyway.
#
# Symptoms of AE not settling: detect debug image appears completely black.
# Fix: increase AE_SETTLE_RETRIES or AE_SETTLE_DELAY, or lower MIN_FRAME_BRIGHTNESS.
MIN_FRAME_BRIGHTNESS=20
AE_SETTLE_RETRIES=10
AE_SETTLE_DELAY=0.1


# ── Detection ────────────────────────────────────────────────────────────────
#
# Maximum long-side resolution (px) for the detection pipeline.
# All processing runs on a downsampled working image; results are scaled back
# to full resolution before homography mapping. 1280 gives sub-second
# detection even at 12MP.
DETECT_MAX_DIM=1280

# Min/Max area filter (in physical mm²).
# Used to reject tiny noise blobs and implausibly large detections.
# A 50×50mm piece = 2 500 mm².  A 400×400mm sheet = 160 000 mm².
MIN_WORKPIECE_AREA_MM2=500
MAX_WORKPIECE_AREA_MM2=160000

# Kernel size for morphological close after hull-fill (px at 720p reference).
# This smooths the convex-hull edges and merges nearby fragments that belong
# to the same workpiece.  Roughly equals 1.5–2× the honeycomb cell diameter.
# Increase if the detection outline has a jagged edge or gaps.
HONEYCOMB_KERNEL_SIZE=25

# Extra pixels to expand the AprilTag exclusion mask beyond the tag border
# (px at 720p reference). Raise if the white paper backing is detected as a
# workpiece.
APRILTAG_MASK_PADDING=30

# ── Background Subtraction (primary — requires reference frame) ───────────────
#
# When the bed is photographed empty during Mapping calibration, that image
# is saved as the reference frame.  On each detection call the pipeline
# computes an absolute per-pixel diff between the live frame and the reference.
# Pixels that changed by more than DETECT_DIFF_THRESHOLD are candidate
# workpiece pixels.  This works for ANY material — bright or dark — because
# it detects change, not absolute brightness.
#
# Panel C of the debug image shows this mask (magenta = changed pixels).
#
# DETECT_DIFF_THRESHOLD (0–255, default 25)
#   Too low  → camera noise / lighting flicker creates false positives.
#   Too high → low-contrast or dark workpieces are missed (Panel C empty).
DETECT_DIFF_THRESHOLD=25

# DETECT_EDGE_PAD_PX (px at working resolution, default 0 = disabled)
#   After the convex hull of all detected fragments is computed, the hull is
#   dilated outward by this many pixels before the final morphological close.
#   This compensates for dark-grained or low-contrast edges that the threshold
#   missed but that belong to the workpiece.
#   0   → no expansion (hull only — correct starting point for most materials)
#   10  → slight expansion for pieces with very dark edges
#   25  → significant expansion (try if detection is consistently undersized)
DETECT_EDGE_PAD_PX=0

# ── Otsu Threshold (fallback — used when no reference frame exists) ───────────
#
# If no reference frame has been saved, the pipeline falls back to Otsu's
# global threshold computed on the ROI pixels.  The honeycomb bed is dark;
# most workpieces are lighter, so Otsu cleanly separates them.
#
# No tuning parameter — Otsu selects the threshold automatically.
# Capture a reference frame (run Mapping calibration with the bed empty) for
# the best results, especially for dark materials (slate, black acrylic).

# ── Canny Edge Detection (Panel E — diagnostic display only) ──────────────────
#
# Canny is NOT used for candidate generation.  It is computed and shown in
# Panel E of the debug image as a visual reference only.
#
# DETECT_CANNY_HIGH (default 60)
#   Upper threshold.  Lower = more edges visible in Panel E.
DETECT_CANNY_HIGH=60


# ── Logging ──────────────────────────────────────────────────────────────────
#
# True   → DEBUG: frame timings, contour counts, threshold values, etc.
# False  → INFO: normal operation only
VISION_DEBUG_LOGGING=True
